:80 {
    # API endpoints → round-robin to nodes
    handle /health {
        reverse_proxy node1:3001 node2:3002 node3:3003
    }
    handle /state {
        reverse_proxy node1:3001 node2:3002 node3:3003
    }
    handle /peers* {
        reverse_proxy node1:3001 node2:3002 node3:3003
    }
    handle /join {
        reverse_proxy node1:3001 node2:3002 node3:3003
    }
    handle /events* {
        reverse_proxy node1:3001 node2:3002 node3:3003
    }
    handle /heads {
        reverse_proxy node1:3001 node2:3002 node3:3003
    }
    handle /sync {
        reverse_proxy node1:3001 node2:3002 node3:3003
    }
    handle /debug/* {
        reverse_proxy node1:3001 node2:3002 node3:3003
    }

    # Everything else → dashboard
    handle {
        reverse_proxy 127.0.0.1:8080
    }
}
