#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "${BASH_SOURCE[0]}")"

# ── Infrastructure (Docker) ──

cmd_infra() {
    docker compose up -d "$@"
    docker compose ps
}

cmd_infra_stop() {
    docker compose down "$@"
}

cmd_infra_logs() {
    docker compose logs -f "$@"
}

# ── Local dev (no Docker) ──

cmd_node() {
    local port="${1:-3001}"
    shift || true
    local db_url="${DATABASE_URL:-postgres://shardd:shardd@localhost/shardd_${port}}"
    echo "Starting node on port ${port} (db: ${db_url})..."
    cargo run -p shardd-node -- --port "$port" --database-url "$db_url" "$@"
}

cmd_cluster() {
    local host="${SHARDD_HOST:-127.0.0.1}"
    local db_base="${SHARDD_DB_BASE:-postgres://shardd:shardd@localhost/shardd}"
    echo "Building release..."
    cargo build --release
    echo "Starting 3-node cluster (host=${host})..."
    ./target/release/shardd-node --host 0.0.0.0 --port 3001 --advertise-addr "${host}:3001" --database-url "${db_base}_a" &
    sleep 1
    ./target/release/shardd-node --host 0.0.0.0 --port 3002 --advertise-addr "${host}:3002" --database-url "${db_base}_b" --bootstrap "${host}:3001" &
    ./target/release/shardd-node --host 0.0.0.0 --port 3003 --advertise-addr "${host}:3003" --database-url "${db_base}_c" --bootstrap "${host}:3001" &
    echo "Cluster running on ports 3001-3003. Press Ctrl+C to stop."
    wait
}

cmd_cluster_stop() {
    echo "Stopping local cluster..."
    pkill -f "shardd-node" || true
}

# ── CLI client ──

cmd_cli() {
    cargo run -p shardd-cli -- "$@"
}

# ── Benchmark ──

cmd_bench() {
    local nodes="${1:-16}"
    shift || true
    echo "Building release..."
    cargo build --release -p shardd-node -p shardd-bench
    echo "Running benchmark with ${nodes} nodes..."
    ./target/release/shardd-bench --nodes "$nodes" --node-bin ./target/release/shardd-node "$@"
}

# ── Dashboard ──

cmd_dashboard() {
    cd apps/dashboard && dx serve --addr 0.0.0.0 --port 8080
}

cmd_dashboard_build() {
    cd apps/dashboard && dx build --release
}

# ── Build ──

cmd_build() {
    echo "Building Docker images..."
    docker build -f apps/node/Dockerfile -t shardd-node:latest .
    docker build -f apps/dashboard/Dockerfile -t shardd-dashboard:latest .
}

# ── Code quality ──

cmd_fmt() {
    cargo fmt --all
}

cmd_lint() {
    cargo clippy --workspace --all-targets "$@"
}

cmd_test() {
    cargo test --workspace "$@"
}

# ── Deploy ──

cmd_deploy() {
    # Load defaults from infra/.env if it exists
    if [ -f infra/.env ]; then
        set -a; source infra/.env; set +a
    fi
    DEPLOY_HOST="${DEPLOY_HOST:?Create infra/.env with DEPLOY_HOST=user@host}"
    DEPLOY_USER="${DEPLOY_USER:-ubuntu}"
    REMOTE_DIR="${REMOTE_DIR:-/opt/shardd}"
    export DEPLOY_HOST DEPLOY_USER REMOTE_DIR
    ./infra/deploy.sh
}

# ── Housekeeping ──

cmd_clean() {
    echo "Removing demo data..."
    rm -rf ./demo
}

# ── Help ──

cmd_help() {
    cat <<'EOF'
Usage: ./run <command>

Infrastructure (Docker):
  infra              Start 3-node cluster via docker compose
  infra:stop         Stop containers
  infra:logs         Tail container logs

Local dev (no Docker):
  node [port] [...]  Run a single node (default port 3001)
  cluster            Build and run a 3-node local cluster
  cluster:stop       Stop local cluster processes

CLI client:
  cli [args]         Run the shardd CLI client

Benchmark:
  bench [N] [...]    Run sync propagation benchmark (default 16 nodes)

Dashboard:
  dashboard          Serve dashboard with hot-reload (dx serve)
  dashboard:build    Build dashboard for production

Build:
  build              Build Docker image

Code quality:
  fmt                Format all Rust code
  lint               Run clippy on all crates
  test               Run all tests

Deploy:
  deploy             Build image and deploy to production

Other:
  clean              Remove demo data directories
  help               Show this help
EOF
}

# ── Router ──

case "${1:-help}" in
    infra)          shift || true; cmd_infra "$@" ;;
    infra:stop)     shift || true; cmd_infra_stop "$@" ;;
    infra:logs)     shift || true; cmd_infra_logs "$@" ;;
    node)           shift || true; cmd_node "$@" ;;
    cluster)        cmd_cluster ;;
    cluster:stop)   cmd_cluster_stop ;;
    cli)            shift; cmd_cli "$@" ;;
    bench)          shift || true; cmd_bench "$@" ;;
    dashboard)      cmd_dashboard ;;
    dashboard:build) cmd_dashboard_build ;;
    build)          cmd_build ;;
    fmt)            cmd_fmt ;;
    lint)           shift || true; cmd_lint "$@" ;;
    test)           shift || true; cmd_test "$@" ;;
    deploy)         cmd_deploy ;;
    clean)          cmd_clean ;;
    help|--help|-h) cmd_help ;;
    *)              echo "Unknown command: $1"; echo; cmd_help; exit 1 ;;
esac
